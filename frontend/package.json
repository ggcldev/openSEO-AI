{
  "name": "openseo-ai-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next && next dev",
    "dev:fast": "next dev",
    "build": "next build",
    "build:bundle-report": "next build && node scripts/bundle-report.mjs",
    "start": "next start",
