POSTGRES_DB=openseo
POSTGRES_USER=openseo
POSTGRES_PASSWORD=openseo

# SQLAlchemy URL for backend + worker.
DATABASE_URL=postgresql+psycopg://openseo:openseo@postgres:5432/openseo

# Frontend browser URL.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Required for live optimization.
GROQ_API_KEY=
LLM_PROVIDER=groq
# Optional: append extra instructions to the content editor prompt.
# Example: "Keep all existing images and avoid adding new sections."
EDITOR_PROMPT_APPEND=

# Worker configuration.
# In Docker Compose: disabled (external worker handles jobs).
# In local dev (uvicorn only): enabled so jobs process without a separate worker.
EMBEDDED_WORKER_ENABLED=true

# Reliability knobs.
JOB_MAX_RETRIES=2
JOB_RETRY_INITIAL_SECONDS=60
JOB_RETRY_MAX_SECONDS=900
SLO_SCRAPE_SUCCESS_TARGET=99.5
SLO_JOB_SUCCESS_TARGET=99.0
SLO_P95_MINUTES_TARGET=15
WORKER_STALE_SECONDS=90
STALE_RUNNING_SECONDS=1800
