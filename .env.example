POSTGRES_DB=openseo
POSTGRES_USER=openseo
POSTGRES_PASSWORD=openseo

# SQLAlchemy URL for backend + worker.
DATABASE_URL=postgresql+psycopg://openseo:openseo@postgres:5432/openseo

# Frontend browser URL.
NEXT_PUBLIC_API_URL=http://localhost:8000
# Comma-separated CORS origins for browser clients.
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Optional client error tracking (Sentry).
NEXT_PUBLIC_SENTRY_DSN=

# Required for live optimization.
GROQ_API_KEY=
LLM_PROVIDER=groq
# Primary Groq model for SEO audit/editor calls.
GROQ_MODEL=llama-3.3-70b-versatile
# Comma-separated fallback models used when primary model is rate-limited.
GROQ_FALLBACK_MODELS=llama-3.1-8b-instant
# Optional: append extra instructions to the content editor prompt.
# Example: "Keep all existing images and avoid adding new sections."
EDITOR_PROMPT_APPEND=
LLM_TIMEOUT_SECONDS=60
LLM_PROVIDER_MAX_RETRIES=1
LLM_CALL_MAX_RETRIES=2
LLM_CALL_RETRY_INITIAL_SECONDS=1.0
LLM_CALL_RETRY_MAX_SECONDS=16.0
LLM_MAX_CONCURRENCY=4

# Worker configuration.
# In Docker Compose: disabled (external worker handles jobs).
# In local dev (uvicorn only): enabled so jobs process without a separate worker.
EMBEDDED_WORKER_ENABLED=true
WORKER_HEARTBEAT_ENABLED=true
SQLITE_WORKER_LOCK_FILE=/tmp/openseo-sqlite-worker.lock

# Reliability knobs.
JOB_MAX_RETRIES=2
JOB_RETRY_INITIAL_SECONDS=60
JOB_RETRY_MAX_SECONDS=900
SLO_SCRAPE_SUCCESS_TARGET=99.5
SLO_JOB_SUCCESS_TARGET=99.0
SLO_P95_MINUTES_TARGET=15
WORKER_STALE_SECONDS=90
STALE_RUNNING_SECONDS=1800

# Database pool settings (Postgres).
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800

# Scraper pressure controls.
STEALTHY_FETCH_MAX_CONCURRENCY=2
COMPETITOR_SCRAPE_MAX_WORKERS=4
SCRAPE_CASCADE_FAIL_MIN_SAMPLES=4
SCRAPE_CASCADE_FAIL_RATIO=0.9
